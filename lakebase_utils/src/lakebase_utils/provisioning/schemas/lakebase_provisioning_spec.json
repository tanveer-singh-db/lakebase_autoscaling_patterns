{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lakebase Provisioning Config",
  "description": "Data-layer provisioning for a Lakebase project: Postgres roles, GRANTs, and Data API exposed schemas. Platform-layer resources (project, branch, endpoint, synced tables) are out of scope and should be managed via databricks.yml.",
  "type": "object",
  "required": ["target"],
  "additionalProperties": false,
  "properties": {
    "target": {
      "type": "object",
      "required": ["project", "branch", "endpoint", "database", "host"],
      "additionalProperties": false,
      "properties": {
        "project":        {"type": "string", "minLength": 1},
        "branch":         {"type": "string", "minLength": 1},
        "endpoint":       {"type": "string", "minLength": 1},
        "database":       {"type": "string", "minLength": 1},
        "host":           {"type": "string", "minLength": 1},
        "workspace_host": {"type": "string"},
        "auth_mode":      {"type": "string", "enum": ["user_oauth", "sp_oauth", "oauth_token"]},
        "profile":        {"type": "string"},
        "client_id":      {"type": "string"},
        "client_secret":  {"type": "string"},
        "oauth_user":     {"type": "string"}
      }
    },

    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["identity", "type"],
        "additionalProperties": false,
        "properties": {
          "identity": {"type": "string", "minLength": 1},
          "type":     {"type": "string", "enum": ["USER", "SERVICE_PRINCIPAL"]}
        }
      }
    },

    "grants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["to"],
        "additionalProperties": false,
        "properties": {
          "to": {"type": "string", "minLength": 1},
          "usage_on_schemas": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "default": []
          },
          "select_on_tables": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z_][A-Za-z0-9_*]*$"},
            "default": [],
            "description": "Fully-qualified schema.table; '*' as the table name expands to all tables in the schema."
          },
          "select_on_all_tables_in_schemas": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "default": []
          },
          "extra_privileges_on_tables": {
            "type": "array",
            "items": {"type": "string", "enum": ["INSERT", "UPDATE", "DELETE"]},
            "default": [],
            "description": "Applied to the same table set as select_on_tables / select_on_all_tables_in_schemas."
          },
          "revoke_existing": {
            "type": "boolean",
            "default": false,
            "description": "If true, REVOKE grants present in the database but absent from this config."
          }
        }
      }
    },

    "exposed_schemas": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },

    "refresh_schema_cache": {
      "type": "boolean",
      "default": true
    }
  }
}
